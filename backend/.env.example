# ─────────────────────────────────────────────────
# AI Resume Builder — Backend Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to source control.

# Your OpenAI API key  (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...your_key_here...

# Port the Express server listens on locally (default: 5000)
PORT=5000

# Allowed origin for CORS — set to your frontend URL
FRONTEND_URL=http://localhost:5173
